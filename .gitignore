coverage
.nyc_output

# Package tarballs (`pnpm pack` / `npm pack` dry-run output)
*.tgz

# Secrets / local config
.env*
.sentryclirc
*.local

# Logs / OS cruft
*.log
pnpm-debug.log*
.DS_Store
